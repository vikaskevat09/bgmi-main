# ===== UPI payment (manual approval) =====
# Customers pay directly to this UPI ID (a QR is generated automatically at
# checkout), upload a payment screenshot, and you approve the order from the
# admin panel — which delivers a code to the customer.
UPI_ID=topupworld@airtel
UPI_NAME=TopUpWorld

PORT=8080

# Allowed browser origin(s) for CORS — the Hostinger domain(s) that call this API.
# Comma-separate multiple. Do NOT use * in production (cookies need a real origin).
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Login cookies are cross-site in a split deploy (frontend + backend on different
# domains), so they must be SameSite=None; Secure. Set this to true on Render.
COOKIE_CROSS_SITE=true

# Secret that signs login/admin session cookies. Use a long random string.
SESSION_SECRET=change-this-to-a-long-random-string

# ===== Admin panel =====
ADMIN_PASSWORD=change-this-strong-password

# ===== ID verification (RapidAPI) =====
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=
RAPIDAPI_URL_TEMPLATE=
RAPIDAPI_DEFAULT_REGION=ind

# ===== Image storage (Cloudinary) — keeps admin uploads permanent =====
# From your Cloudinary dashboard. If left blank, uploads save to local disk
# (which is temporary on Render free tier).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
